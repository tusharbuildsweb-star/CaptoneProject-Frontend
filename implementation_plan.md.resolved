│   ├── booking/         (Checkout, Payment, BookingSuccess)
│   ├── user/            (Dashboard, Reservations, Reviews, Favorites, Tickets)
│   ├── owner/           (Dashboard, ReservationMgmt, MenuMgr, ReviewsMgmt, Tickets)
│   └── admin/           (Dashboard, Users, Restaurants, Reviews, Support)
├── layouts/             (MainLayout, DashboardLayout, AuthLayout)
├── context/             (AuthContext, SocketContext)
├── hooks/               (useAuth, useSocket, useRestaurants)
├── services/            (api.js, auth.js, restaurants.js, reservations.js, reviews.js)
├── routes/              (AppRoutes.jsx, ProtectedRoute.jsx)
└── assets/              (images, icons)
```

